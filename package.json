{
  "name": "discord-logging-bot",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "npm run build --workspace=@logger/shared && npm run build --workspace=@logger/db",
    "dev:bot": "npm run dev --workspace=@logger/bot",
    "dev:dashboard": "npm run dev --workspace=@logger/dashboard",
    "start": "concurrently \"npm run start --workspace=@logger/dashboard\" \"npm run start --workspace=@logger/bot\"",
    "build": "npm run build --workspaces --if-present"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "tsx": "^4.7.1"
  }
}
